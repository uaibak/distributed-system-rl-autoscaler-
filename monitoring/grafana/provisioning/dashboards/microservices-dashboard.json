{
  "uid": "microservices-phase1",
  "title": "Microservices Monitoring - Phase 1",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total[1m]) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency (s)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket[1m])) by (le, service))",
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU/Memory Usage (containers)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{container=~\\\"distributed-frontend|distributed-backend\\\"}[1m])) by (container)",
          "legendFormat": "{{container}} CPU",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{container=~\\\"distributed-frontend|distributed-backend\\\"}",
          "legendFormat": "{{container}} MEM",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Service Health",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "up{job=~\\\"frontend|backend\\\"}",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Instance Count",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "count by (job) (up)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(flask_http_request_total{status=~\\\"5..\\\"}[1m]) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
